rules_version = '2';

// =============================================================================
//  Règles de sécurité Firestore — My Watch
//  ---------------------------------------------------------------------------
//  Équivalent de la sécurité au niveau ligne (RLS) : chaque utilisateur ne peut
//  lire et écrire QUE dans son propre sous-arbre users/{uid}/…
//  (bibliotheque, episodes_vus). À coller dans la console Firebase :
//  Firestore Database → Rules → Publish.
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
