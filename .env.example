# =============================================================================
#  Variables d'environnement de My Watch
#  ---------------------------------------------------------------------------
#  1. Copie ce fichier en ".env"          ->  cp .env.example .env
#  2. Remplis les valeurs ci-dessous.
#  3. Ne commite JAMAIS le fichier ".env" (il est déjà dans .gitignore).
#
#  Astuce Expo : toute variable préfixée par EXPO_PUBLIC_ est accessible
#  directement dans le code via process.env.EXPO_PUBLIC_...
# =============================================================================

# --- TMDb (The Movie Database) : source des films et séries -----------------
# Crée un compte gratuit sur https://www.themoviedb.org puis va dans
# Paramètres > API pour obtenir ta clé. On utilise le "jeton d'accès v4"
# (Bearer token) qui est le plus simple.
EXPO_PUBLIC_TMDB_ACCESS_TOKEN=colle_ici_ton_jeton_v4_tmdb

# --- Firebase : base de données (Firestore) + authentification --------------
# 1. Crée un projet sur https://console.firebase.google.com
# 2. Ajoute une application "Web" (icône </>) : la config affichée te donne les
#    valeurs ci-dessous.
# 3. Active "Authentication" (méthode E-mail/mot de passe) et "Firestore Database".
# 4. Colle le contenu de firestore.rules dans Firestore Database > Rules.
EXPO_PUBLIC_FIREBASE_API_KEY=colle_ici_ta_cle_api
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=ton-projet.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=ton-projet
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=ton-projet.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# --- Trakt.tv (optionnel) : synchro automatique de l'historique -------------
# Crée une application sur https://trakt.tv/oauth/applications
#   - Redirect URI : urn:ietf:wg:oauth:2.0:oob (flux "device", pas de redirection)
# Puis copie l'ID client et le secret ci-dessous.
# ⚠️ Trakt impose le secret côté client (pas de flux public) : il sera embarqué
#    dans l'app. C'est le compromis accepté par les clients Trakt tiers.
EXPO_PUBLIC_TRAKT_CLIENT_ID=colle_ici_ton_client_id_trakt
EXPO_PUBLIC_TRAKT_CLIENT_SECRET=colle_ici_ton_client_secret_trakt
